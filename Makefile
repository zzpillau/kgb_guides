# Сборка и запуск
dev:
	npm run dev

build:
	npm run build

preview:
	npm run preview

# Проверка и форматирование
check:
	npm run check

fix:
	npm run fix

format:
	npm run format

# Деплой
predeploy:
	npm run predeploy

deploy:
	npm run deploy

# Стили
style:
	npm run style

.PHONY: dev build preview lint predeploy deploy style