{
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "formatWithErrors": true
  },
  "javascript": {
    "formatter": {
      "semicolons": "asNeeded",
      "quoteStyle": "single"
    }
  },
  "linter": {
    "enabled": true
  },
  "files": {
    "includes": ["src/**/*.js", "src/**/*.jsx", "src/**/*.scss"]
  }
}
